# Various IDEs and Editors
.vscode/
.idea/
**/*~

# Mac OSX temporary files
.DS_Store
**/.DS_Store

# mops packages
.mops/

# icp-cli local state (root) — keep only the mainnet canister id mapping
/.icp/*
!/.icp/data
/.icp/data/*
!/.icp/data/mappings
/.icp/data/mappings/*
!/.icp/data/mappings/ic.ids.json

# icp-cli local state in the test project (nothing to keep)
test/.icp/

# generated proposal arguments (regenerate with scripts/make_proposal_args.py)
proposal_args/

# python bytecode cache
__pycache__/

# planning / working docs (kept local, not committed)
docs/
notes/
